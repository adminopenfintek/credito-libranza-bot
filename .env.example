# =========================================================
#  WHATSAPP CLOUD API (Meta)
# =========================================================
# Token PERMANENTE generado desde un System User en Meta Business Suite.
# NO uses el token temporal (expira en 24h).
WHATSAPP_TOKEN=EAAG...tu_token_permanente

# ID del numero de telefono (Phone Number ID) que aparece en el panel
# de WhatsApp > API Setup. NO es el numero telefonico, es un ID numerico.
WHATSAPP_PHONE_NUMBER_ID=1234567890

# Version del Graph API. Deja v21.0 salvo que Meta indique otra.
GRAPH_API_VERSION=v21.0

# Nombre EXACTO de la plantilla aprobada en Meta (minusculas y guiones bajos).
WHATSAPP_TEMPLATE_NAME=asesoria_libranza_invitacion

# Codigo de idioma de la plantilla (debe coincidir con el aprobado en Meta).
# es = espanol generico | es_CO = espanol Colombia
WHATSAPP_TEMPLATE_LANG=es

# URL publica de la IMAGEN que va en el header de la plantilla.
# Debe ser https, JPG o PNG, menor a 5MB. La forma facil: subes la imagen
# a tu repo de GitHub y pegas aqui la URL "raw" (te explico en el README).
WHATSAPP_HEADER_IMAGE_URL=https://raw.githubusercontent.com/tu_usuario/credito-libranza-bot/main/assets/banner.jpg

# =========================================================
#  GOOGLE SHEETS
# =========================================================
# ID del Sheet: esta en la URL entre /d/ y /edit
# https://docs.google.com/spreadsheets/d/ESTE_ES_EL_ID/edit
GOOGLE_SHEET_ID=1AbCdEfGhIjKlMnOpQrStUvWxYz

# Nombre de la pestania (hoja) donde estan los datos.
GOOGLE_SHEET_TAB=Hoja1

# Ruta al archivo JSON de la cuenta de servicio de Google.
GOOGLE_CREDENTIALS_PATH=./credentials/google-credentials.json

# =========================================================
#  COMPORTAMIENTO DEL ENVIO
# =========================================================
# Codigo de pais por defecto si un numero viene sin el (57 = Colombia).
DEFAULT_COUNTRY_CODE=57

# Milisegundos de espera entre cada mensaje (evita superar limites/spam).
DELAY_MS=1500

# Cuantos mensajes enviar en paralelo (mantenlo bajo: 1-3).
CONCURRENCY=1

# Maximo de mensajes a enviar por ejecucion (respeta tu tier de Meta).
MAX_PER_RUN=200

# =========================================================
#  WEBHOOK (opcional, solo si corres server.js)
# =========================================================
WEBHOOK_VERIFY_TOKEN=un_texto_secreto_que_tu_inventas
PORT=3000
